  email alex.barbalex@gmail.com
  acme_ca https://acme.zerossl.com/v2/DV90
  #acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
  #debug
}

auth.xn--arten-frdern-bjb.app {
  @auth_arten_preflight {
    method OPTIONS
    header Origin https://xn--arten-frdern-bjb.app
  }

  handle @auth_arten_preflight {
    header Access-Control-Allow-Origin "https://xn--arten-frdern-bjb.app"
    header Access-Control-Allow-Methods "GET,POST,PUT,DELETE,OPTIONS"
    header Access-Control-Allow-Headers "Authorization, Content-Type"
    header Access-Control-Allow-Credentials "true"
    header Vary "Origin"
    respond "" 204
  }

  @auth_arten_origin header Origin https://xn--arten-frdern-bjb.app
  header @auth_arten_origin Access-Control-Allow-Origin "https://xn--arten-frdern-bjb.app"
  header @auth_arten_origin Access-Control-Allow-Credentials "true"
  header @auth_arten_origin Vary "Origin"

  reverse_proxy * ps_auth:3003 {
    header_down -Access-Control-Allow-Origin
    header_down -Access-Control-Allow-Credentials
    header_down -Vary
  }
}

# use caddy to cache requests to electric, see: https://electric-sql.com/docs/guides/deployment#caching-proxy
# https://electric-sql.com/docs/api/http#caching
sync.xn--arten-frdern-bjb.app {
  reverse_proxy * ps_electric:3000 {
    # Disable buffering so SSE events are flushed immediately
    flush_interval -1
    header_down Access-Control-Allow-Origin *
  }

  encode gzip
}

api.xn--arten-frdern-bjb.app {
  @arten_preflight {
    method OPTIONS
    header Origin https://xn--arten-frdern-bjb.app
  }

  handle @arten_preflight {
    header Access-Control-Allow-Origin "https://xn--arten-frdern-bjb.app"
    header Access-Control-Allow-Methods "GET,POST,PATCH,PUT,DELETE,OPTIONS"
    header Access-Control-Allow-Headers "Authorization, Content-Type, Prefer, Range"
    header Access-Control-Allow-Credentials "true"
    header Access-Control-Expose-Headers "Content-Range, Content-Location"
    header Vary "Origin"
    respond "" 204
  }

  @arten_origin header Origin https://xn--arten-frdern-bjb.app
  header @arten_origin Access-Control-Allow-Origin "https://xn--arten-frdern-bjb.app"
  header @arten_origin Access-Control-Allow-Credentials "true"
  header @arten_origin Access-Control-Expose-Headers "Content-Range, Content-Location"
  header @arten_origin Vary "Origin"

  reverse_proxy * ps_postgrest:3002 {
    header_down -Access-Control-Allow-Origin
  }
}

auth.promote-species.app {
  @auth_promote_preflight {
    method OPTIONS
    header Origin https://promote-species.app
  }

  @auth_arten_app_preflight {
